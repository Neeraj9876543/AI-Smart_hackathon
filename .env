# Backend Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# For local development (requires MongoDB running locally)
# MONGODB_URI=mongodb://localhost:27017/student-success-hub

# For production deployment (MongoDB Atlas - free cloud database)
MONGODB_URI=mongodb+srv://demo:demo123@cluster0.mongodb.net/student-success-hub?retryWrites=true&w=majority

# Google OAuth Configuration
GOOGLE_CLIENT_ID=485182531995-guq60ejs56jlatbtfmtjqhlk6ec0r6tr.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=7d

# Frontend Configuration (for deployment)
VITE_API_BASE_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000

# Production URLs (update these when deploying)
# VITE_API_BASE_URL=https://your-backend-domain.com
# VITE_FRONTEND_URL=https://your-frontend-domain.com

# Google OAuth Production URLs (update these when deploying)
# GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/auth/google/callback

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (if needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

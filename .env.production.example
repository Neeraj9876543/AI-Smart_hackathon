# Production Environment Variables Template
# Copy this to .env.production and update with your actual deployment URLs

# Backend Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (use MongoDB Atlas or production database)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/student-success-hub

# Google OAuth Configuration (update with production credentials)
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/auth/google/callback

# JWT Configuration (use a strong secret in production)
JWT_SECRET=your-super-secure-jwt-secret-key-for-production
JWT_EXPIRES_IN=7d

# Frontend Configuration (for deployment)
VITE_API_BASE_URL=https://your-backend-domain.com
VITE_FRONTEND_URL=https://your-frontend-domain.com

# CORS Configuration (add your deployed frontend URL)
ALLOWED_ORIGINS=https://your-frontend-domain.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (if needed)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
